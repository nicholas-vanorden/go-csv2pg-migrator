database:
  # Used unless -postgres-dsn is provided on the CLI.
  dsn: "postgres://user:pass@localhost:5432/mydb?sslmode=disable"

options:
  # Boolean CLI flags are true when provided; otherwise use these values (default: false).
  dry_run: false
  stop_on_error: false
  # CLI -batch-size is used only if > 0. Otherwise this value is used (default: 1000).
  batch_size: 100 # default: 1000
  # tables still created when dry_run: true
  create_tables_if_not_exist: false

# Tables will be loaded in the order they are defined here.
# If a table has foreign key/s, make sure to define it after the tables it depends on.
tables:
  - name: users
    file: data/users.csv
    truncate_before_load: true
    columns:
      id:
        source: USER_ID
        type: TEXT
      email:
        source: EMAIL_ADDRESS
        type: TEXT
      created_at:
        source: CREATED_DATE
        transform: date
        type: DATE
      is_active:
        source: ACTIVE_FLAG
        transform: boolean
        type: BOOLEAN
    ignore_columns:
      - LEGACY_STATUS

  - name: orders
    file: data/orders.csv
    truncate_before_load: true
    columns:
      id:
        source: ORDER_ID
        type: TEXT
      user_id:
        source: USER_ID
        type: TEXT
      total:
        source: TOTAL_AMOUNT
        type: NUMERIC(12,2)
        transform: money
      created_at:
        source: CREATED_DATE
        transform: date
        type: DATE
